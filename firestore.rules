rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic user info is readable by any authenticated user
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Plans subcollection: readable by all auth users (filtering done in code)
      // and writable only by the owner
      match /plans/{planId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Private subcollections (notifications, friends) only accessible by the owner
      match /notifications/{id} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /friends/{id} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(userId)));
      }
    }

    // Rules for plans, notifications, and friend requests
    match /plans/{planId} {
      allow read, write: if request.auth != null;
    }

    match /friendRequests/{requestId} {
      allow read, write: if request.auth != null;
    }
  }
}
